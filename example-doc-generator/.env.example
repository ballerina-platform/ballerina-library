# =============================================================================
# Python Configuration — connector-docs-automations
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# .env is git-ignored — never commit it.
# =============================================================================

# ── Server ports ──────────────────────────────────────────────────────────────
# Must match codeServerPort / agentServerPort in Config.toml
CODE_SERVER_PORT=8080
AGENT_SERVER_PORT=8765

# ── Local repository paths ────────────────────────────────────────────────────
# Path to your local clone of the integration-samples fork
INTEGRATION_SAMPLES_REPO=../../integration-samples
# Path to your local clone of the docs-integrator fork
DOCS_INTEGRATOR_REPO=../../docs-integrator

# ── GitHub repository identifiers ─────────────────────────────────────────────
# GitHub org/repo to target for integration samples PRs
INTEGRATION_SAMPLES_UPSTREAM=wso2/integration-samples
# Base branch for integration samples PRs
INTEGRATION_SAMPLES_BASE_BRANCH=main
# Your fork of docs-integrator to push feature branches to (org/repo) — required
DOCS_INTEGRATOR_FORK=your-org/docs-integrator
# Upstream docs-integrator repo to open PRs against (org/repo)
DOCS_INTEGRATOR_UPSTREAM=wso2/docs-integrator
# Base branch for docs-integrator PRs
DOCS_INTEGRATOR_BASE_BRANCH=main

# ── Screenshot crop margins (pixels) ─────────────────────────────────────────
# Tuned for a 1720x968 headless Playwright / code-server viewport
CROP_TOP=32
CROP_BOTTOM=18
CROP_LEFT=0
CROP_RIGHT=0
